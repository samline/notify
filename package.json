{
  "name": "@samline/sonner",
  "version": "2.0.7",
  "description": "An opinionated toast component for React.",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "default": "./dist/index.js"
    },
    "./react": {
      "import": {
        "types": "./dist/react/index.d.mts",
        "default": "./dist/react/index.mjs"
      },
      "require": {
        "types": "./dist/react/index.d.ts",
        "default": "./dist/react/index.js"
      },
      "default": "./dist/react/index.js"
    },
    "./core": {
      "import": {
        "types": "./dist/core/index.d.mts",
        "default": "./dist/core/index.mjs"
      },
      "require": {
        "types": "./dist/core/index.d.ts",
        "default": "./dist/core/index.js"
      },
      "default": "./dist/core/index.js"
    },
    "./browser": {
      "import": {
        "types": "./dist/browser/index.d.mts",
        "default": "./dist/browser/index.mjs"
      },
      "require": {
        "types": "./dist/browser/index.d.ts",
        "default": "./dist/browser/index.js"
      },
      "default": "./dist/browser/index.js"
    },
    "./vue": {
      "import": {
        "types": "./dist/vue/index.d.mts",
        "default": "./dist/vue/index.mjs"
      },
      "require": {
        "types": "./dist/vue/index.d.ts",
        "default": "./dist/vue/index.js"
      },
      "default": "./dist/vue/index.js"
    },
    "./svelte": {
      "import": {
        "types": "./dist/svelte/index.d.mts",
        "default": "./dist/svelte/index.mjs"
      },
      "require": {
        "types": "./dist/svelte/index.d.ts",
        "default": "./dist/svelte/index.js"
      },
      "default": "./dist/svelte/index.js"
    },
    "./styles.css": "./dist/styles.css",
    "./dist/styles.css": "./dist/styles.css"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bunchee --watch",
    "build": "bunchee && cp src/styles.css dist/styles.css",
    "type-check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run tests/runtime.test.ts tests/state.test.ts --environment node --globals",
    "test:watch": "vitest tests/runtime.test.ts tests/state.test.ts --environment node --globals"
  },
  "keywords": [
    "react",
    "vue",
    "svelte",
    "vanilla-js",
    "browser",
    "notifications",
    "toast",
    "snackbar",
    "message"
  ],
  "author": "Emil Kowalski <e@emilkowal.ski>",
  "license": "MIT",
  "homepage": "https://sonner.emilkowal.ski/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/emilkowalski/sonner.git"
  },
  "bugs": {
    "url": "https://github.com/emilkowalski/sonner/issues"
  },
  "devDependencies": {
    "@types/node": "^18.11.13",
    "@types/react": "^18.0.26",
    "bunchee": "6.3.3",
    "prettier": "^2.8.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^4.8.4",
    "vitest": "^2.1.8"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "react-dom": "^18.0.0 || ^19.0.0 || ^19.0.0-rc",
    "vue": "^3.4.0",
    "svelte": "^4.2.0 || ^5.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    },
    "vue": {
      "optional": true
    },
    "svelte": {
      "optional": true
    }
  },
  "packageManager": "pnpm@9.15.9"
}
